# ── FinMind API Token（免費版即可）────────────────────────────────
# 至 https://finmindtrade.com 免費註冊後取得
# 影響功能：月營收、季財報、現金流量（合約負債）、資産負債（固定資產）
FINMIND_TOKEN = "your_finmind_token_here"

# ── Proxy 中繼站（格式：http://用戶:密碼@主機:埠）──────────────────
# 影響功能：PMI、CPI(BLS)、NDC景氣、出口等總經數據更新
# 例：PROXY_URL = "http://username:password@your.proxy.host:3128"
PROXY_URL = "http://username:password@your.proxy.host:3128"

# ── 其他 API Keys（選填）─────────────────────────────────────────
# GEMINI_API_KEY = "your_gemini_key"  # AI 功能
