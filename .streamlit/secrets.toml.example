# ════════════════════════════════════════════════════════════════════════════
# Streamlit Secrets 模板（完整版 — 涵蓋 code 內所有 secrets key）
# ════════════════════════════════════════════════════════════════════════════
#
# 用法：
#   1. 複製本檔為 secrets.toml（同資料夾）：
#        cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2. 把 <...> 占位符換成真實值
#   3. 不需要的選填項目用 # 註解掉
#
# Streamlit Cloud 部署：
#   Settings → Secrets → 直接貼下方內容（去掉註解列也可）
#
# ⚠️ secrets.toml 已被 .gitignore 排除，永遠不要 commit 真實值
# ════════════════════════════════════════════════════════════════════════════


# ── §1 必填：FinMind API（核心資料源）────────────────────────────────────────
# 至 https://finmindtrade.com 免費註冊取得 JWT Token
# 影響功能：月營收、季財報、現金流量（合約負債）、資産負債（固定資產）、
#           ETF 成分股、台股技術指標
FINMIND_TOKEN = "<paste_your_finmind_jwt_token_here>"

# 帳密 fallback（選填，僅當 token 失效時 code 會嘗試帳密登入）
# FINMIND_USER     = "<your_finmind_email_or_username>"
# FINMIND_PASSWORD = "<your_finmind_password>"


# ── §2 選填：AI 與美國總經 ───────────────────────────────────────────────────
# Google Gemini — AI 摘要 / 教練模式
# 申請：https://aistudio.google.com/app/apikey
GEMINI_API_KEY = "<paste_your_gemini_api_key_here>"

# FRED（美國聯準會經濟數據）— 殖利率曲線、美國 CPI、失業率等
# 申請：https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY = "<paste_your_fred_api_key_here>"


# ── §3 選填：NAS Proxy（總經數據備援通道）──────────────────────────────────
# 用途：PMI、CPI(BLS)、NDC 景氣、出口等被 Cloudflare/防火牆擋時走 NAS 中繼
# 影響檔：proxy_helper.py / yield_screener.py / leading_indicators.py
#
# 格式 A（推薦，一條龍）：
PROXY_URL = "http://<user>:<password>@<nas_ip_or_domain>:<port>"
# 範例：PROXY_URL = "http://corn:p@ssw0rd@192.168.1.100:3128"

# 格式 B（拆分，app.py L854/L872 會讀；A 已填可省略 B）：
# PROXY_HOST = "<nas_ip_or_domain>"
# PROXY_PORT = "<port>"

# 別名（部分模組會優先讀此 key，留著兼容）：
# NAS_PROXY_URL = "http://<user>:<password>@<nas_ip>:<port>"


# ── §4 選填：自架 NAS Server（nas_server.py）─────────────────────────────────
# 若你在 NAS 上跑了 nas_server.py 當代理 API server，需設此 key 做請求驗證
# Code 位置：nas_server.py L34  → _API_KEY = os.environ.get("NAS_API_KEY", "")
# NAS_API_KEY = "<your_self_defined_random_long_string>"


# ════════════════════════════════════════════════════════════════════════════
# 驗證指令（填完後跑這個確認每組 key 都通）：
#   python final_check.py
# ════════════════════════════════════════════════════════════════════════════
