# Secrets - NEVER commit
.streamlit/secrets.toml

# Notebook (contains hardcoded API keys)
*.ipynb
.ipynb_checkpoints/

# Python
__pycache__/
*.py[cod]
*.pyo
.env

# Temp / cache
temp/
*.pkl
*.cache
*.csv
*.xlsx

# Runtime state (generated at runtime, must not be committed)
macro_state.json

# Test coverage
.coverage
htmlcov/
coverage.xml

# OS
.DS_Store
Thumbs.db
desktop.ini

# Debug protocol artifacts (cleaned up at end of session)
*.bak
debug.log

# Runtime data cache (regenerated at runtime; keep dir via .gitkeep)
data_cache/*.parquet
data_cache/metadata.json

# Local push helper scripts (contain local paths / account names — never commit)
*.vbs
